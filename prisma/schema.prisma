// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TrustLevel {
  NEWCOMER
  MEMBER
  TRUSTED
  VERIFIED
}

enum AvailStatus {
  OPEN
  FOCUS
  BUSY
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum ProjectCategory {
  LOMBA
  STARTUP
  KREATIF
  BELAJAR
  SOSIAL
  AKADEMIK
  BISNIS
  PERTANIAN
  TEKNOLOGI
  PERKANTORAN
  KESEHATAN
  HUKUM
  TEKNIK
  SENI
  OLAHRAGA
  KULINER
  SAINS
}

enum CommitmentLevel {
  CASUAL
  SERIUS
  KOMPETISI
}

enum ProjectTopic {
  TEKNOLOGI
  PERTANIAN
  PENDIDIKAN
  LINGKUNGAN
  EKONOMI
  KARYA_TULIS
  RESEARCH
  PENGABDIAN
  KESEHATAN
  SENI_BUDAYA
  HUKUM_POLITIK
  MANUFAKTUR
  KULINER_PARIWISATA
  OLAHRAGA_KEBUGARAN
  MARITIM_DIRGANTARA
  SAINS_MURNI
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum HubRoomType {
  ANNOUNCEMENT
  GENERAL
  KANBAN
  CUSTOM
}

enum AITool {
  PROJECT_BRIEF_GENERATOR
  SKILL_GAP_ANALYZER
  PROJECT_RECOMMENDATION
  REVIEW_SUMMARIZER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  username          String?   @unique
  emailVerified     DateTime?
  image             String?
  bio               String?
  linkedinUrl       String?
  portfolioUrl      String?
  githubUrl         String?
  trustScore        Int       @default(20)
  trustLevel        TrustLevel @default(NEWCOMER)
  availStatus       AvailStatus @default(OPEN)
  isStudentVerified Boolean   @default(false)
  password          String?
  otpCode           String?
  otpExpiry         DateTime?
  onboardingDone    Boolean   @default(false)
  role              UserRole  @default(USER)
  isBlocked         Boolean   @default(false)

  skills            UserSkill[]
  projectsOwned     Project[]  @relation("owner")
  memberships       ProjectMember[]
  reviewsGiven      PeerReview[] @relation("reviewer")
  reviewsReceived   PeerReview[] @relation("reviewed")
  endorsementsReceived SkillEndorsement[] @relation("endorsed")
  endorsementsGiven SkillEndorsement[] @relation("endorser")
  bookmarks         Bookmark[]
  sessions          Session[]
  accounts          Account[]
  reportsSent       Report[]   @relation("reportsSent")
  projectBans       ProjectBan[]
  projectReportsSent ProjectReport[] @relation("reporter")
  projectReportsTarget ProjectReport[] @relation("reported")
  hubMessages       HubMessage[]
  externalLinks     ExternalLink[]
  notifications     Notification[]
  feedPosts         FeedPost[]
  feedLikes         FeedLike[]
  feedComments      FeedComment[]
  feedBookmarks     FeedBookmark[]
  feedReports       FeedReport[]
  aiUsage           AIToolUsage[]
  aiResults         AIToolResult[]

  invitationsSent     Invitation[] @relation("invitationsSent")
  invitationsReceived Invitation[] @relation("invitationsReceived")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSkill {
  id        String @id @default(cuid())
  userId    String
  skillName String

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillName])
}

model Project {
  id              String   @id @default(cuid())
  title           String
  description     String
  category        ProjectCategory
  commitmentLevel CommitmentLevel
  projectTopic    ProjectTopic @default(TEKNOLOGI)
  maxMembers      Int
  status          ProjectStatus @default(OPEN)
  ownerId         String
  deadline        DateTime?

  owner           User     @relation("owner", fields: [ownerId], references: [id])
  requiredSkills  ProjectSkill[]
  members         ProjectMember[]
  tasks           Task[]
  chatMessages    ChatMessage[]
  polls           Poll[]
  bookmarks       Bookmark[]
  applications    Application[]
  hubRooms        HubRoom[]
  hubTasks        HubTask[]
  feedPosts       FeedPost[]
  bans            ProjectBan[]
  internalReports ProjectReport[]
  invitations     Invitation[]
  reviews         PeerReview[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProjectSkill {
  id        String @id @default(cuid())
  projectId String
  skillName String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillName])
}

model ProjectMember {
  id            String   @id @default(cuid())
  projectId     String
  userId        String
  isAnonymous   Boolean  @default(false)
  anonymousTag  String?
  revealedAt    DateTime?
  role          MemberRole @default(MEMBER)
  roleTitle     String?
  joinedAt      DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Application {
  id              String   @id @default(cuid())
  projectId       String
  applicantId     String
  message         String
  commitmentLevel CommitmentLevel
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Invitation {
  id        String   @id @default(cuid())
  projectId String
  inviterId String
  inviteeId String
  status    String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter   User     @relation("invitationsSent", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User     @relation("invitationsReceived", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([projectId, inviteeId])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  assigneeId  String?
  labelTag    String?
  deadline    DateTime?
  position    Int        @default(0)

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  senderId  String
  content   String
  mentions  String[] @default([])

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Poll {
  id        String   @id @default(cuid())
  projectId String
  creatorId String
  question  String
  isActive  Boolean  @default(true)

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  options   PollOption[]

  createdAt DateTime @default(now())
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  text   String

  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  PollVote[]
}

model PollVote {
  id       String @id @default(cuid())
  optionId String
  userId   String

  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
}

model PeerReview {
  id           String   @id @default(cuid())
  projectId    String
  reviewerId   String
  reviewedId   String
  rating       Int
  behaviorTags String[]
  comment      String?

  reviewer     User     @relation("reviewer", fields: [reviewerId], references: [id])
  reviewed     User     @relation("reviewed", fields: [reviewedId], references: [id])
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@unique([projectId, reviewerId, reviewedId])
}

model SkillEndorsement {
  id          String @id @default(cuid())
  endorsedId  String
  endorserId  String
  skillName   String

  endorsed    User   @relation("endorsed", fields: [endorsedId], references: [id], onDelete: Cascade)
  endorser    User   @relation("endorser", fields: [endorserId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([endorsedId, endorserId, skillName])
}

model Bookmark {
  id        String @id @default(cuid())
  userId    String
  projectId String

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

// ─── Collab Hub ──────────────────────────────────────────────────────────────

model HubRoom {
  id           String      @id @default(cuid())
  projectId    String
  name         String
  description  String?
  type         HubRoomType @default(CUSTOM)
  passwordHash String?

  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages     HubMessage[]
  tasks        HubTask[]

  createdAt    DateTime    @default(now())
}

model HubMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  content   String
  mentions  String[] @default([])

  room      HubRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

model HubTask {
  id          String     @id @default(cuid())
  roomId      String?
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  assigneeId  String?
  labelTag    String?
  deadline    DateTime?
  position    Int        @default(0)
  isGlobal    Boolean    @default(false)

  room        HubRoom?   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "MENTION", "TASK", "APPLICATION", "SYSTEM", "INVITATION"
  link      String?
  invitationId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model FeedPost {
  id          String       @id @default(cuid())
  authorId    String
  type        FeedPostType // CONTRIBUTION | EVENT
  content     String       // maks 500 karakter untuk contribution, 280 untuk event
  mediaUrl    String?      // opsional, URL gambar (contribution)
  projectTopic ProjectTopic?
  impactTag   String?

  // Khusus contribution post
  projectId   String?

  // Khusus event post
  eventName   String?
  eventCategory EventCategory?
  eventDeadline DateTime?
  eventLink   String?
  eventSkills String[]     // array skill tag

  tags        String[]     @default([]) // Untuk menyimpan hashtag dari content

  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author      User         @relation(fields: [authorId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  likes       FeedLike[]
  comments    FeedComment[]
  bookmarks   FeedBookmark[]
  reports     FeedReport[]
}

model FeedLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  parentId  String?
  authorId  String
  content   String   // maks 200 karakter
  mentions  String[] // array userId yang di-mention
  createdAt DateTime @default(now())

  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    FeedComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   FeedComment[] @relation("CommentReplies")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model FeedBookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model FeedReport {
  id        String   @id @default(cuid())
  postId    String
  reporterId String
  reason    String
  createdAt DateTime @default(now())

  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter  User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterId])
}

enum FeedPostType {
  CONTRIBUTION
  EVENT
}

enum EventCategory {
  LOMBA
  HACKATHON
  WORKSHOP
  SEMINAR
  ESSAY_AKADEMIK
  BISNIS_UMKM
  LAINNYA
}


model ExternalLink {
  id             String           @id @default(cuid())
  userId         String
  platform       ExternalPlatform
  url            String
  label          String?          // untuk custom link
  username       String?          // diekstrak dari URL
  status         LinkStatus       @default(PENDING)
  visibility     LinkVisibility   @default(MEMBERS_ONLY)

  // Cache metadata untuk preview
  previewTitle   String?
  previewImage   String?

  verifiedAt     DateTime?
  lastCheckedAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ExternalPlatform {
  LINKEDIN
  GITHUB
  BEHANCE
  DRIBBBLE
  PORTFOLIO
  INSTAGRAM
  YOUTUBE
  CUSTOM
}

enum LinkStatus {
  PENDING
  VERIFIED
  UNVERIFIED
  REJECTED
}

enum LinkVisibility {
  PUBLIC
  MEMBERS_ONLY
  COLLABORATORS_ONLY
}

model AIToolUsage {
  id        String   @id @default(cuid())
  userId    String
  toolType  AITool
  usedAt    DateTime @default(now())
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id])
  result    AIToolResult?

  @@index([userId, toolType])
}

model AIToolResult {
  id        String   @id @default(cuid())
  usageId   String   @unique
  userId    String
  toolType  AITool
  input     Json
  output    Json
  createdAt DateTime @default(now())

  user      User         @relation(fields: [userId], references: [id])
  usage     AIToolUsage  @relation(fields: [usageId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  targetId    String   // Could be project ID or user ID
  targetType  String   // "PROJECT" or "USER"
  reason      String
  description String?
  status      String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  createdAt   DateTime @default(now())

  reporter    User     @relation("reportsSent", fields: [reporterId], references: [id])
}

model ProjectBan {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  reason    String?
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectReport {
  id          String   @id @default(cuid())
  projectId   String
  reporterId  String
  reportedId  String
  reason      String
  description String?
  status      String   @default("PENDING") // PENDING, KICKED, BANNED, DISMISSED
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter    User     @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported    User     @relation("reported", fields: [reportedId], references: [id], onDelete: Cascade)
}
